# =========================================================
#  LÚMEN — configuração do servidor
#  Copie este arquivo para ".env" e preencha o que for usar.
# =========================================================

PORT=8080

# --- Trava da BETA (login exigido para abrir o app) ---
# Preencha os dois para exigir senha. Deixe em branco para deixar o app aberto.
BETA_USER=lumen
BETA_PASS=troque_esta_senha
# Limite de mensagens por IP (protege seus créditos)
CHAT_RATE_MAX=40
CHAT_RATE_WINDOW_MIN=10

# --- IA (obrigatório para a conversa real) ---
# Sua chave da Anthropic: https://console.anthropic.com  -> API Keys
ANTHROPIC_API_KEY=coloque_sua_chave_aqui
ANTHROPIC_MODEL=claude-sonnet-4-5

# --- WhatsApp de emergência (alertas automáticos) ---
# Provedor: none | twilio | zapi
WHATSAPP_PROVIDER=none
# Número que recebe os alertas de risco (com DDI 55)
GUARDIAN_PHONE=5512996531629

# Opção A — Twilio (https://twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Opção B — Z-API (gateway brasileiro, https://z-api.io)
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# --- E-mail dos relatórios (envio automático) ---
REPORT_EMAIL_TO=rodrigoamerico2019@gmail.com
# SMTP (ex.: Gmail com "senha de app" — não é a senha normal da conta)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_de_app_de_16_digitos
SMTP_FROM=Lúmen <seu_email@gmail.com>

# --- Contas e histórico por paciente (Etapa 1) ---
# Banco Postgres (Neon: https://neon.tech — gratuito). Guarda contas, convites e conversas.
DATABASE_URL=postgresql://usuario:senha@host/db?sslmode=require
# Segredo dos tokens de sessão (gere uma string longa aleatória)
JWT_SECRET=gere_uma_chave_aleatoria_longa
# Chave do mentor p/ gerar convites: /api/admin/invite?key=SUA_CHAVE&note=Nome
ADMIN_KEY=defina_uma_chave_de_admin

# --- Notificações push do app (PWA) ---
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:seu_email@gmail.com
# Lembretes automáticos de bem-estar (on/off)
REMINDERS=on
